# helpy.kv
<HelpyInterface>:
    canvas.before:
        Color:
            rgba: 0.1, 0.1, 0.1, 0.9  # Темный стильный фон (90% прозрачности)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [40, 40, 0, 0] # Закругленные углы сверху

    # Сам Хелпи (Твой анимированный персонаж)
    Image:
        id: helpy_img
        source: 'assets/helpy.png' # Убедись, что картинка тут!
        size_hint: (0.4, 0.4)
        pos_hint: {'center_x': 0.5, 'center_y': 0.6}
        allow_stretch: True

    # Поле ввода для пароля 201321
    TextInput:
        id: pass_input
        hint_text: "Введите код доступа..."
        password: True
        multiline: False
        size_hint: (0.7, 0.07)
        pos_hint: {'center_x': 0.5, 'center_y': 0.3}
        background_color: [1, 1, 1, 0.1]
        foreground_color: [1, 1, 1, 1]
        cursor_color: [1, 1, 1, 1]
        on_text_validate: root.check_password(self.text)

    # Статус нейросети
    Label:
        id: status_label
        text: "Helpy Assistant: Система активна"
        font_size: '14sp'
        color: [0.5, 0.8, 1, 1] # Неоновый голубой
        pos_hint: {'center_x': 0.5, 'center_y': 0.15}